# ============================================================================
# FERRETERÍA POS - CONFIGURACIÓN
# Copiar este archivo a backend/.env y editar según tu entorno

# ENTORNO
NODE_ENV=development
PORT=3000

# BASE DE DATOS
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=ferreteria_pos

# JWT - AUTENTICACIÓN
JWT_SECRET=tu-secret-key-super-segura-cambiar-en-produccion
JWT_EXPIRATION=3600
JWT_REFRESH_SECRET=tu-refresh-secret-key-super-segura-cambiar
JWT_REFRESH_EXPIRATION=604800

# SEGURIDAD
BCRYPT_ROUNDS=10
CORS_ORIGIN=http://localhost:4200

# LOGGING
LOG_LEVEL=debug
LOG_DIR=./logs

# DEVELOPMENT
SWAGGER_ENABLED=true
SWAGGER_PATH=/api/docs

