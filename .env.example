# ============================================================================
# FERRETERIA POS - CONFIGURACIÓN POR DEFECTO
# Copiar a .env y actualizar con valores específicos del entorno
# ============================================================================

# ============================================================================
# ENTORNO
# ============================================================================
NODE_ENV=development
PORT=3000
APP_NAME=Ferreteria POS API
APP_VERSION=1.0.0

# ============================================================================
# BASE DE DATOS - PostgreSQL
# ============================================================================
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=ferreteria_pos
DB_SYNCHRONIZE=false
DB_LOGGING=true
DB_SSL=false

# Pool de Conexiones
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT=10000
DB_IDLE_TIMEOUT=30000

# ============================================================================
# REDIS (Opcional - para caché y sesiones)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL=3600

# ============================================================================
# JWT - Autenticación
# ============================================================================
JWT_SECRET=tu-secret-key-super-segura-cambiar-en-produccion
JWT_EXPIRATION=3600
JWT_REFRESH_SECRET=tu-refresh-secret-key-super-segura-cambiar-en-produccion
JWT_REFRESH_EXPIRATION=604800

# ============================================================================
# SEGURIDAD
# ============================================================================
BCRYPT_ROUNDS=10
CORS_ORIGIN=http://localhost:4200
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=debug
LOG_FORMAT=combined
LOG_DIR=./logs

# ============================================================================
# EMAIL (para notificaciones)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu-password-app
SMTP_FROM=ferreteria@example.com
SMTP_TLS=true

# ============================================================================
# ALMACENAMIENTO DE ARCHIVOS
# ============================================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf

# ============================================================================
# AWS S3 (Opcional - para almacenamiento en nube)
# ============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ============================================================================
# INTEGRACIÓN CON SERVICIOS EXTERNOS
# ============================================================================
# Facturación Electrónica
FACTURA_API_KEY=
FACTURA_API_URL=

# Pasarelas de Pago
PAYMENT_GATEWAY_KEY=
PAYMENT_GATEWAY_SECRET=

# ============================================================================
# AUDITORÍA Y MONITOREO
# ============================================================================
ENABLE_AUDIT_LOG=true
AUDIT_RETENTION_DAYS=365

# Sentry (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ============================================================================
# CONFIGURACIÓN DE2FA (Autenticación de Dos Factores)
# ============================================================================
TFA_ENABLED=false
TFA_WINDOW_SIZE=2

# ============================================================================
# TIMEOUTS Y LIMITES
# ============================================================================
REQUEST_TIMEOUT=30000
INACTIVITY_TIMEOUT=1800000
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_TIME=900000

# ============================================================================
# CONFIGURACIÓN DE DATOS INICIALES
# ============================================================================
INITIALIZE_DEFAULT_USERS=true
DEFAULT_ADMIN_EMAIL=admin@ferreteria.com
DEFAULT_ADMIN_PASSWORD=Admin@123

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================
DEBUG=ferreteria:*
SWAGGER_ENABLED=true
SWAGGER_PATH=/api/docs

# ============================================================================
# FIN DE CONFIGURACIÓN
# ============================================================================
